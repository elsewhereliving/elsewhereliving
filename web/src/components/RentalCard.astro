---
// Faithful port of js/pages.js RentalCard.
import Icon from "./Icon.astro";
import Badge from "./Badge.astro";
import SaveButton from "./react/SaveButton.tsx";
import { viewList } from "../lib/format";
import type { Rental } from "../lib/types";
interface Props { item: Rental; href?: string; }
const { item, href } = Astro.props;
const link = href ?? `/rentals/${item.id}/`;
const views = viewList(item.view);
// nightlyOriginal / nightlyCurrency may appear in the data (PriceTag tooltip).
const nightlyOriginal = (item as any).nightlyOriginal as string | undefined;
const nightlyCurrency = (item as any).nightlyCurrency as string | undefined;
const priceTip = nightlyOriginal
  ? `Shown in USD — originally ${nightlyOriginal}${nightlyCurrency ? ` (${nightlyCurrency})` : ""}`
  : undefined;
---
<a href={link} class="pcard" aria-label={item.title}>
  <div class="pcard__media pcard__media--32 ew-grain">
    <img src={item.image} alt={item.title} loading="lazy" decoding="async" style={`object-position:${item.imageFocal || "center"}`} />
    {views.length > 0 && (
      <div style="position:absolute; top:14px; left:14px; z-index:2; display:flex; flex-wrap:wrap; gap:6px;">
        {views.map((v) => <Badge tone="light">{v}</Badge>)}
      </div>
    )}
    <div style="position:absolute; top:12px; right:12px; z-index:2;"><SaveButton id={item.id} client:visible /></div>
  </div>
  <div style="padding:22px 24px 26px;">
    <div style="font-family:var(--font-sans); font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--slate);">{item.location}</div>
    <h3 style="margin:8px 0 0; font-family:var(--font-serif); font-weight:300; font-size:27px; line-height:1.1; letter-spacing:-0.01em; color:var(--navy);">{item.title}</h3>
    <div style="display:flex; gap:16px; margin-top:12px; font-family:var(--font-sans); font-weight:300; font-size:12.5px; letter-spacing:0.03em; color:var(--text-body);">
      <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="bed" size={15} color="var(--slate)" stroke={1.4} /> {item.bedsLabel || item.beds}</span>
      <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="users" size={15} color="var(--slate)" stroke={1.4} /> {item.guestsLabel || item.guests} guests</span>
      <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="interior" size={15} color="var(--slate)" stroke={1.4} /> {item.size}</span>
    </div>
    <div style="display:flex; align-items:baseline; justify-content:space-between; gap:18px; margin-top:20px; padding-top:18px; border-top:1px solid var(--border-subtle);">
      <span style="display:flex; flex-direction:column; flex:none;">
        {!item.nightlyFixed && <span style="font-family:var(--font-sans); font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--slate);">From</span>}
        <span style="font-family:var(--font-serif); font-weight:400; font-size:22px; color:var(--charcoal);">
          {nightlyOriginal ? (
            <span style="position:relative; display:inline-flex; align-items:center; gap:7px;" title={priceTip}>
              <span style="border-bottom:1px dotted var(--stone); padding-bottom:1px;">{item.nightly}</span>
              <Icon name="info" size={16} color="var(--slate)" stroke={1.5} />
            </span>
          ) : (
            item.nightly
          )}<span style="font-family:var(--font-sans); font-size:12px; color:var(--slate); letter-spacing:0.04em;"> / night</span>
        </span>
      </span>
      {item.note && <span style="flex:0 1 auto; min-width:0; max-width:50%; text-align:right; line-height:1.4; font-family:var(--font-sans); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--slate);">{item.note}</span>}
    </div>
  </div>
</a>
