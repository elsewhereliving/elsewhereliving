---
// Faithful port of the design-system Badge (window.DesignSystem_abef38).
interface Props { tone?: "outline" | "navy" | "accent" | "mist" | "light"; class?: string; }
const { tone = "outline", class: klass = "" } = Astro.props;
const TONES: Record<string, string> = {
  outline: "background:transparent;color:var(--charcoal);border:1px solid var(--border-subtle);",
  navy: "background:var(--navy);color:var(--white);border:1px solid var(--navy);",
  accent: "background:var(--butter);color:var(--navy);border:1px solid var(--butter);",
  mist: "background:var(--mist);color:var(--navy);border:1px solid var(--mist);",
  light: "background:var(--white);color:var(--charcoal);border:1px solid var(--border-subtle);",
};
const base = "display:inline-flex;align-items:center;gap:0.4em;font-family:var(--font-sans);font-weight:400;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;padding:0.45em 0.85em;border-radius:var(--radius-xs);line-height:1;";
---
<span class={`ew-badge ${klass}`} style={base + TONES[tone]}><slot /></span>
