---
// Faithful port of js/brand.js PropertyCard. Takes a full listing `item`.
import Icon from "./Icon.astro";
import Badge from "./Badge.astro";
import SaveButton from "./react/SaveButton.tsx";
import { viewBadges, viewText } from "../lib/format";
import { optImg, optImgSrcset, CARD_SIZES } from "../lib/img";
import type { Listing } from "../lib/types";

interface Props { item: Listing; href?: string; }
const { item, href } = Astro.props;
const link = href ?? `/property/${item.id}/`;
const isLand = item.type === "Land";
const tooltip = item.priceOriginal
  ? `Shown in USD — originally ${item.priceOriginal}${item.priceCurrency ? ` (${item.priceCurrency})` : ""}`
  : undefined;
---
<a href={link} class="pcard" aria-label={item.title}>
  <div class="pcard__media pcard__media--32 ew-grain">
    <img src={optImg(item.image, "main")} srcset={optImgSrcset(item.image)} sizes={optImgSrcset(item.image) ? CARD_SIZES : undefined} alt={item.title} loading="lazy" decoding="async" width="640" height="427" style={`object-position:${item.imageFocal || "center"}`} onerror={`this.onerror=null;this.removeAttribute('srcset');this.src='${item.image}'`} />
    <div style="position:absolute; top:14px; left:14px; z-index:2; display:flex; flex-wrap:wrap; gap:6px;">
      {item.status && <Badge tone="light">{item.status}</Badge>}
      {viewBadges(item.view).map((v) => <Badge tone="light">{v}</Badge>)}
    </div>
    <div style="position:absolute; top:12px; right:12px; z-index:2;"><SaveButton id={item.id} client:visible /></div>
  </div>
  <div class="pcard__body">
    <div style="font-family:var(--font-sans); font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--slate);">{item.location}</div>
    <h3 style="margin:8px 0 0; font-family:var(--font-serif); font-weight:300; font-size:26px; line-height:1.12; color:var(--navy); letter-spacing:-0.01em;">{item.title}</h3>
    <div style="display:flex; flex-wrap:wrap; gap:8px 16px; margin-top:16px; padding-top:16px; border-top:1px solid var(--border-subtle); font-family:var(--font-sans); font-weight:300; font-size:12.5px; letter-spacing:0.03em; color:var(--text-body);">
      {isLand ? (
        <>
          <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="plot" size={15} color="var(--slate)" stroke={1.4} /> {item.plot}</span>
          <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="view" size={15} color="var(--slate)" stroke={1.4} /> {viewText(item.view)}</span>
        </>
      ) : (
        <>
          <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="bed" size={15} color="var(--slate)" stroke={1.4} /> {item.bedsLabel || item.beds}</span>
          <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="bath" size={15} color="var(--slate)" stroke={1.4} /> {item.baths}</span>
          {item.interior && item.interior !== "—" && (
            <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="interior" size={15} color="var(--slate)" stroke={1.4} /> {item.interior}</span>
          )}
          {item.plot && item.plot !== "—" && (
            <span style="display:inline-flex; align-items:center; gap:6px;"><Icon name="plot" size={15} color="var(--slate)" stroke={1.4} /> {item.plot}</span>
          )}
        </>
      )}
    </div>
    <div style="margin-top:16px; display:flex; align-items:baseline; justify-content:space-between; gap:12px;">
      {item.priceOriginal ? (
        <span style="position:relative; display:inline-flex; align-items:center; gap:7px;" title={tooltip}>
          <span style="font-family:var(--font-serif); font-weight:400; font-size:19px; color:var(--charcoal); border-bottom:1px dotted var(--stone); padding-bottom:1px;">{item.price}</span>
          <Icon name="info" size={14} color="var(--slate)" stroke={1.5} />
        </span>
      ) : (
        <span style="font-family:var(--font-serif); font-weight:400; font-size:19px; color:var(--charcoal);">{item.price}</span>
      )}
    </div>
  </div>
</a>
